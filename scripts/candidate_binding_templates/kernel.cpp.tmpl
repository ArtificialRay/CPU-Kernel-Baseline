// Reference-scalar conv2d — port of ref_conv.h::ref_conv2d.
// LLM target: replace this file with an optimised inner_conv2d.
// All per-definition constants live in conv2d_def:: (conv2d.h).
#include "conv2d.h"
using namespace conv2d_def;

extern "C" void inner_conv2d(
    const float* input, float* output, const float* weight,
    int N, int H, int W, int H_out, int W_out)
{
    for (int n = 0; n < N; ++n) {
        const float* in_n = input + (long)n * Cin * H * W;
        float* out_n = output + (long)n * Cout * H_out * W_out;
        for (int oc = 0; oc < Cout; ++oc) {
            float* outc = out_n + (long)oc * H_out * W_out;
            for (int oh = 0; oh < H_out; ++oh) {
                for (int ow = 0; ow < W_out; ++ow) {
                    float sum = 0.0f;
                    for (int ic = 0; ic < Cin; ++ic) {
                        const float* inc = in_n + (long)ic * H * W;
                        for (int kh = 0; kh < Kh; ++kh) {
                            for (int kw = 0; kw < Kw; ++kw) {
                                int ih = oh * Sh - pad_top  + kh * Dh;
                                int iw = ow * Sw - pad_left + kw * Dw;
                                float px = (ih >= 0 && ih < H && iw >= 0 && iw < W)
                                           ? inc[ih * W + iw] : 0.0f;
                                int widx = ((oc * Cin + ic) * Kh + kh) * Kw + kw;
                                sum += px * weight[widx];
                            }
                        }
                    }
                    if (activation_type == 1 && sum < 0.0f) sum = 0.0f;
                    outc[oh * W_out + ow] = sum;
                }
            }
        }
    }
}
