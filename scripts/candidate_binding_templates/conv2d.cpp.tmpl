// Binding harness: computes output dims from constexpr params, calls inner_conv2d.
// The ctypes mirror of armbench_entry_conv2d is bench/datasets/raw.py
// SIGNATURES["conv2d"] — edit one, edit the other.
#include "conv2d.h"
using namespace conv2d_def;

extern "C" int armbench_entry_conv2d(
    const float* input, float* output,
    const float* weight,
    int N, int H, int W)
{
    constexpr int ext_kh = Dh * (Kh - 1) + 1;
    constexpr int ext_kw = Dw * (Kw - 1) + 1;
    const int H_out = (H + 2 * pad_top  - ext_kh) / Sh + 1;
    const int W_out = (W + 2 * pad_left - ext_kw) / Sw + 1;
    inner_conv2d(input, output, weight, N, H, W, H_out, W_out);
    return 0;
}