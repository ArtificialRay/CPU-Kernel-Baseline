test_tensor.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_tensor.dir/build.make CMakeFiles/test_tensor.dir/test_tensor.cpp.i
.PHONY : test_tensor.cpp.i

test_tensor.s: test_tensor.cpp.s
.PHONY : test_tensor.s

# target to generate assembly for a file
test_tensor.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_tensor.dir/build.make CMakeFiles/test_tensor.dir/test_tensor.cpp.s
.PHONY : test_tensor.cpp.s

