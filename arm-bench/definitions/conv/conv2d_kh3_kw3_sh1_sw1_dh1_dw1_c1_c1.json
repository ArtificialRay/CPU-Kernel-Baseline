{
  "name": "conv2d_kh3_kw3_sh1_sw1_dh1_dw1_c1_c1",
  "op_type": "conv2d",
  "description": "Smallest 2D conv smoke definition: 3x3 kernel, stride 1, dilation 1, 1->1 channels. Used to validate the bench pipeline end-to-end with a hand-computable output.",
  "tags": ["status:draft", "isa:sve"],
  "axes": {
    "N":     {"type": "var"},
    "H":     {"type": "var", "parent": "N"},
    "W":     {"type": "var", "parent": "N"},
    "H_out": {"type": "var", "parent": "N", "description": "Derived: (H + 2*pad - (Kh-1)*Dh - 1) / Sh + 1"},
    "W_out": {"type": "var", "parent": "N", "description": "Derived: (W + 2*pad - (Kw-1)*Dw - 1) / Sw + 1"},
    "C_in":  {"type": "const", "value": 1},
    "C_out": {"type": "const", "value": 1},
    "Kh":    {"type": "const", "value": 3},
    "Kw":    {"type": "const", "value": 3},
    "Sh":    {"type": "const", "value": 1},
    "Sw":    {"type": "const", "value": 1},
    "Dh":    {"type": "const", "value": 1},
    "Dw":    {"type": "const", "value": 1}
  },
  "inputs": {
    "input":  {"shape": ["N", "C_in", "H", "W"],         "dtype": "float32"},
    "weight": {"shape": ["C_out", "C_in", "Kh", "Kw"],   "dtype": "float32"},
    "bias":   {"shape": ["C_out"],                       "dtype": "float32"}
  },
  "outputs": {
    "output": {"shape": ["N", "C_out", "H_out", "W_out"], "dtype": "float32"}
  },
  "constraints": [
    "H_out == (H - Kh) / Sh + 1",
    "W_out == (W - Kw) / Sw + 1"
  ],
  "reference": "import torch\nimport torch.nn.functional as F\n\ndef run(input, weight, bias):\n    x = torch.from_numpy(input)\n    w = torch.from_numpy(weight)\n    b = torch.from_numpy(bias)\n    y = F.conv2d(x, w, b, stride=(1, 1), padding=(0, 0), dilation=(1, 1))\n    return y\n"
}
